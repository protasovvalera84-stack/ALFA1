# =====================================================
# Конфигурация «Альфа Юнит-1»
#
# БЫСТРЫЙ СТАРТ (автоматически):
#   sudo ./setup.sh          ← рекомендуется!
#
# ВРУЧНУЮ:
#   cp .env.example .env
#   Отредактируйте нужные параметры ниже
#   docker compose up -d
# =====================================================

# Порт HTTP сервера (80 уже пробрасывается в docker-compose.yml)
PORT=8080

# Путь к файлу базы данных SQLite (внутри контейнера)
DB_PATH=/app/data/alfa1.db

# Домен сайта (для sitemap.xml, canonical URLs, SEO)
# Пример: https://alfaunit1.ru  или  http://186.246.12.46
# Без слеша в конце!
SITE_DOMAIN=http://YOUR_SERVER_IP

# Пароль администратора для входа в /admin/
# Используйте надёжный пароль — минимум 12 символов
# setup.sh генерирует его автоматически
ADMIN_PASSWORD=YourStrongPasswordHere

# Секрет для подписи сессий (минимум 32 символа, случайные)
# Сгенерировать: openssl rand -base64 32
# setup.sh генерирует его автоматически
SESSION_SECRET=replace-with-random-32-char-secret-here

# Режим работы: development или production
APP_ENV=production
