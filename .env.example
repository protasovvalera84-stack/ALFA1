# =====================================================
# Конфигурация «Альфа Юнит-1»
# Скопировать в .env и заполнить своими значениями
# =====================================================

# Порт HTTP сервера
PORT=8080

# Путь к файлу базы данных SQLite
DB_PATH=./data/alfa1.db

# Домен сайта (для sitemap.xml, canonical URLs, HTTPS)
# Без слеша в конце!
SITE_DOMAIN=https://alfaunit1.ru

# Начальный пароль администратора
# ОБЯЗАТЕЛЬНО сменить после первого запуска!
ADMIN_PASSWORD=ChangeMe2026!

# Секрет для подписи сессий (минимум 32 символа, случайные)
# Сгенерировать: openssl rand -base64 32
SESSION_SECRET=replace-this-with-a-very-long-random-secret-key-12345

# Режим работы: development или production
APP_ENV=production
